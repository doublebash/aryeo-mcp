{
  "name": "aryeo-mcp",
  "version": "2.0.0",
  "description": "Cloudflare Workers Model Context Protocol server bridging Claude to the Aryeo real-estate media platform — listings, orders, customers, products, scheduling, appointments. Built on @bashco/mcp-toolkit.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "anthropic",
    "aryeo",
    "real-estate",
    "cloudflare-workers",
    "oauth"
  ],
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@bashco/mcp-toolkit": "^1.0.0",
    "hono": "^4.12.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.40",
    "@cloudflare/workers-types": "^4.20260426.1",
    "typescript": "^5.7.2",
    "vitest": "~2.1.9",
    "wrangler": "^4.90.0"
  },
